meta {
  name: register
  type: http
  seq: 1
}

post {
  url: {{BASE_URL}}/auth/register
  body: json
  auth: inherit
}

body:json {
  {
    "name": "John Doe",
    "email": "john.doe@example.com",
    "password": "StrongPassword123"
  }
  
}

vars:pre-request {
  BASE_URL: http://localhost:8080/api/v1
}

settings {
  encodeUrl: true
  timeout: 0
}
